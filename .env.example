# ============================================================
# Configuration Frontend — Copier ce fichier en .env
# et renseigner les valeurs pour votre environnement
# ============================================================

# URL de l'API billariz-corp
REACT_APP_HOST_API=http://localhost:8080/v1/

# AWS Cognito — Authentification
REACT_APP_COGNITO_USER_POOL_ID=eu-west-3_XXXXXXXXX
REACT_APP_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_AWS_REGION=eu-west-3
REACT_APP_COGNITO_DOMAIN=billariz-corp

# Pour le développement local sans Cognito, commenter les lignes ci-dessus
# et utiliser le mode d'authentification local (basic auth Spring Boot Admin)
